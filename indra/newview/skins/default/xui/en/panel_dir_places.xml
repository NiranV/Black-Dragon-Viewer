<panel
 border="true"
 top="30"
 follows="left|top|right|bottom"
 height="533"
 label="Places"
 left="1"
 mouse_opaque="false"
 name="panel_dir_places"
 width="758">
    <string name="searching_text">
        Searching...
    </string>
    <string name="not_found_text">
        None Found.
    </string>

     <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="443"
    layout="topleft"
    left="2"
    top_pad="2"/>
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     top_delta="2"
     follows="left|right|top"
     layout="topleft"
     font="SansSerif"
     height="20"
     left_delta="2"
     max_length="63"
     mouse_opaque="true"
     name="name"
     width="439" />
     <combo_box
     allow_text_entry="false"
     follows="right|top"
     layout="topleft"
     height="25"
     top_delta="-2"
     left_pad="3"
     max_chars="20"
     mouse_opaque="true"
     name="Category"
     width="128">
        <combo_item name="AnyCategory" value="any" label="Any Category"/>
        <combo_item name="LindenLocation" value="linden" label="Linden Location"/>
        <combo_item name="Arts&amp;Culture" value="arts" label="Arts &amp; Culture"/>
        <combo_item name="Business" value="store" label="Business"/>
        <combo_item name="Educational" value="educational" label="Educational"/>
        <combo_item name="Gaming" value="game" label="Gaming"/>
        <combo_item name="Hangout" value="gather" label="Hangout"/>
        <combo_item name="NewcomerFriendly" value="newcomer" label="Newcomer Friendly"/>
        <combo_item name="Parks&amp;Nature" value="park" label="Parks &amp; Nature"/>
        <combo_item name="Residential" value="home" label="Residential"/>
        <combo_item name="Shopping" value="shopping" label="Shopping"/>
        <combo_item name="Adult" value="adult" label="Adult"/>
        <combo_item name="Other" value="other" label="Other"/>
        <combo_box.combo_button
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
		<combo_box.drop_down_button
		pad_right="0"
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_pressed="ToolbarDropDown_Press" 
		image_pressed_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
    </combo_box>
    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowPGSims"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_PG_Dark"
     mouse_opaque="true"
     name="incpg"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowMatureSims"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_M_Dark"
     mouse_opaque="true"
     name="incmature"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowAdultSims"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_R_Dark"
     mouse_opaque="true"
     name="incadult"
     width="25" />

    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     left_pad="1"
     height="25"
     label="Search"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     mouse_opaque="true"
     name="Search"
     width="103" />
    <scroll_list
     background_visible="true"
     layout="topleft"
     top_pad="1"
     column_padding="0"
     draw_border="false"
     draw_heading="true"
     follows="left|top|right|bottom"
     height="480"
     left="2"
     mouse_opaque="true"
     multi_select="false"
     name="results"
     search_column="2"
     width="336">
     <column label="" name="icon" width="24" />
        <column dynamicwidth="true" label="Name" name="name" />
        <column label="Traffic" name="dwell" width="75" />
    </scroll_list>
    <button
     image_overlay="Arrow_Left_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     hover_glow_amount="0.15"
     tool_tip="Previous page"
     follows="left|bottom"
     layout="topleft"
     height="23"
     left="2"
     top_pad="1"
     name="prev_btn"
     width="32" />
     <icon
    follows="left|bottom|right"
    image_name="Toolbar_Middle_Off"
    height="23"
    width="270"
    layout="topleft"
    left_pad="1"
    top_delta="0"/>
    <text
     bg_visible="false"
     border_visible="false"
     top_delta="5"
     follows="left|bottom"
     font="SansSerifSmall"
     h_pad="0"
     halign="center"
     height="16"
     left_delta="2"
     layout="topleft"
     mouse_opaque="true"
     name="result_text"
     v_pad="0"
     width="267" >
     500 found
</text>
    <button
     image_overlay="Arrow_Right_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     tool_tip="Next page"
     follows="right|bottom"
     height="23"
     layout="topleft"
     left_pad="2"
     name="next_btn"
     top_delta="-5"
     width="32"/>
</panel>
