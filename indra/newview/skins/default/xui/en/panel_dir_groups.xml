<panel
 border="true"
 top="30"
 follows="left|top|right|bottom"
 height="533"
 label="Groups"
 left="1"
 mouse_opaque="false"
 name="panel_dir_groups"
 width="758">
 <string name="searching_text">
   Searching...
</string>
<string name="not_found_text">
   None Found.
</string>

     <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="650"
    layout="topleft"
    left="2"
    top_pad="2"/>
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     top_delta="2"
     follows="left|right|top"
     layout="topleft"
     font="SansSerif"
     height="20"
     left_delta="2"
     max_length="63"
     mouse_opaque="true"
     name="name"
     width="486" />
     <check_box
     top_delta="1"
     control_name="ShowMatureGroups"
     follows="right|top"
     layout="topleft"
     font="SansSerifSmall"
     height="16"
     initial_value="false"
     label="Include Mature groups"
     left_pad="1"
     mouse_opaque="true"
     name="incmature"
     width="159" />
    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="-3"
     left_pad="3"
     height="25"
     label="Search"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     mouse_opaque="true"
     name="Search"
     width="103" />
    <scroll_list
     background_visible="true"
     layout="topleft"
     top_pad="1"
     column_padding="0"
     draw_border="false"
     draw_heading="true"
     follows="left|top|right|bottom"
     height="480"
     left="2"
     mouse_opaque="true"
     multi_select="false"
     name="results"
     search_column="2"
     width="336">
     <column label="" name="icon" width="24" sort="score" sort_ascending="false" />
     <column label="" name="type" width="-1" />
     <column label="Name" name="name" dynamicwidth="true" />
     <column label="Members" name="members" width="100" halign="left" sort_ascending="false" />
     <column label="" name="score" width="-1"/>
    </scroll_list>
    <button
     image_overlay="Arrow_Left_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     hover_glow_amount="0.15"
     tool_tip="Previous page"
     follows="left|bottom"
     layout="topleft"
     height="23"
     left="2"
     top_pad="1"
     name="prev_btn"
     width="32" />
     <icon
    follows="left|bottom|right"
    image_name="Toolbar_Middle_Off"
    height="23"
    width="270"
    layout="topleft"
    left_pad="1"
    top_delta="0"/>
    <text
     bg_visible="false"
     border_visible="false"
     top_delta="5"
     follows="left|bottom"
     font="SansSerifSmall"
     h_pad="0"
     halign="center"
     height="16"
     left_delta="2"
     layout="topleft"
     mouse_opaque="true"
     name="result_text"
     v_pad="0"
     width="267" >
</text>
    <button
     image_overlay="Arrow_Right_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     tool_tip="Next page"
     follows="right|bottom"
     height="23"
     layout="topleft"
     left_pad="2"
     name="next_btn"
     top_delta="-5"
     width="32"/>
</panel>
