<panel
 border="true"
 top="30"
 default_tab_group="1"
 follows="left|top|right|bottom"
 height="533"
 label="Events"
 left="1"
 mouse_opaque="false"
 name="panel_dir_events"
 width="758">
    <string name="searching_text">
        Searching...
    </string>
    <string name="not_found_text">
        None Found.
    </string>

    <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="174"
    layout="topleft"
    left="2"
    top_pad="2"/>
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     top_delta="2"
     follows="left|right|top"
     layout="topleft"
     font="SansSerif"
     height="20"
     left_delta="2"
     max_length="63"
     mouse_opaque="true"
     name="event_search_text"
     width="170" />
     <combo_box
     allow_text_entry="false"
     follows="top|right"
     layout="topleft"
     height="25"
     top_delta="-2"
     left_pad="3"
     max_chars="20"
     mouse_opaque="true"
     name="type"
     width="128">
        <combo_item name="All" value="0" label="Any Category"/>
        <combo_item name="Discussion" value="18" label="Discussion"/>
        <combo_item name="Sports" value="19" label="Sports"/>
        <combo_item name="LiveMusic" value="20" label="Live Music"/>
        <combo_item name="LiveDJ" value="30" label="Live DJ"/>
        <combo_item name="Commercial" value="22" label="Commercial"/>
        <combo_item name="Nightlife/Entertainment" value="23" label="Nightlife/Entertainment"/>
        <combo_item name="Games/Contests" value="24" label="Games/Contests"/>
        <combo_item name="Pageants" value="25" label="Pageants"/>
        <combo_item name="Education" value="26" label="Education"/>
        <combo_item name="ArtsandCulture" value="27" label="Arts and Culture"/>
        <combo_item name="Charity/SupportGroups" value="28" label="Charity/Support Groups"/>
        <combo_item name="Miscellaneous" value="29" label="Miscellaneous"/>
        <combo_box.combo_button
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
		<combo_box.drop_down_button
		pad_right="0"
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_pressed="ToolbarDropDown_Press" 
		image_pressed_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
    </combo_box>
    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowLandEvents"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_PG_Dark"
     mouse_opaque="true"
     name="incpg"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowMatureEvents"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_M_Dark"
     mouse_opaque="true"
     name="incmature"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowAdultEvents"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_R_Dark"
     mouse_opaque="true"
     name="incadult"
     width="25" />
     <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="205"
    layout="topleft"
    left_pad="-2"
    top_delta="0"/>
    <radio_group
     top_delta="0"
     draw_border="false"
     follows="top|right"
     layout="topleft"
     height="16"
     left_delta="0"
     mouse_opaque="true"
     name="date_mode"
     initial_value="current"
     width="200">
        <radio_item
         layout="topleft"
         left="3"
         top="0"
         follows="left|top"
         height="20"
         mouse_opaque="true"
         name="current"
         width="170"
         label="In-Progress &amp; Upcoming"/>
        <radio_item
         layout="topleft"
         follows="left|top"
         height="20"
         top_delta="0"
         left_delta="151"
         mouse_opaque="true"
         name="date"
         width="56"
         label="Date"/>
    </radio_group>
    <button
     top_delta="0"
     left_pad="3"
     layout="topleft"
     follows="left|top"
     font="SansSerif"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     halign="center"
     height="25"
     label="&lt;&lt;"
     label_selected="&lt;&lt;"
     left_delta="54"
     mouse_opaque="true"
     name="back_btn"
     tool_tip="Go back a day"
     width="20" />
     <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="35"
    layout="topleft"
    left_pad="1"
    top_delta="0"/>
    <text
     top="8"
     bg_visible="false"
     border_visible="false"
     left_delta="0"
     layout="topleft"
     drop_shadow_visible="true"
     follows="left|top"
     font="SansSerif"
     h_pad="0"
     halign="center"
     height="14"
     mouse_opaque="true"
     name="date_text"
     v_pad="0"
     width="32">
        6/6
    </text>
    <button
     top_delta="-6"
     left_pad="1"
     layout="topleft"
     follows="left|top"
     font="SansSerif"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     halign="center"
     height="25"
     label="&gt;&gt;"
     label_selected="&gt;&gt;"
     left_delta="50"
     mouse_opaque="true"
     name="forward_btn"
     tool_tip="Go forward a day"
     width="20" />

    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     left_pad="4"
     height="25"
     label="Search"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     mouse_opaque="true"
     name="Search"
     width="94" />
    <scroll_list
     background_visible="true"
     layout="topleft"
     top_pad="1"
     column_padding="0"
     draw_border="false"
     draw_heading="true"
     follows="left|top|right|bottom"
     height="480"
     left="2"
     mouse_opaque="true"
     multi_select="false"
     name="results"
     search_column="2"
     width="336">
    <column label="" name="icon" width="24" />
    <column label="" name="type" width="-1" />
    <column dynamicwidth="true" label="Name" name="name" />
    <column label="Time (PT)" name="date" sort="time" width="106" />
    <column label="" name="event_id" width="-1" />
    <column label="Time" name="time" width="-1" />
    </scroll_list>
    <button
     image_overlay="Arrow_Left_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     hover_glow_amount="0.15"
     tool_tip="Previous page"
     follows="left|bottom"
     layout="topleft"
     height="23"
     left="2"
     top_pad="1"
     name="prev_btn"
     width="32" />
     <icon
    follows="left|bottom|right"
    image_name="Toolbar_Middle_Off"
    height="23"
    width="270"
    layout="topleft"
    left_pad="1"
    top_delta="0"/>
    <text
     bg_visible="false"
     border_visible="false"
     top_delta="5"
     follows="left|bottom"
     font="SansSerifSmall"
     h_pad="0"
     halign="center"
     height="16"
     left_delta="2"
     layout="topleft"
     mouse_opaque="true"
     name="result_text"
     v_pad="0"
     width="267" >
</text>
    <button
     image_overlay="Arrow_Right_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     tool_tip="Next page"
     follows="right|bottom"
     height="23"
     layout="topleft"
     left_pad="2"
     name="next_btn"
     top_delta="-5"
     width="32"/>

</panel>
