<panel border="true" top="30" follows="left|top|right|bottom" height="533"
     label="Land Sales" left="1" mouse_opaque="false" name="panel_dir_land"
     width="758">
    <string name="searching_text">
        Searching...
    </string>
    <string name="not_found_text">
        None Found.
    </string>
    
    <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="174"
    layout="topleft"
    left="2"
    top_pad="2"/>
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     top_delta="2"
     follows="left|right|top"
     layout="topleft"
     font="SansSerif"
     height="20"
     left_delta="2"
     max_length="63"
     mouse_opaque="true"
     name="name"
     width="170" />
     <combo_box
     allow_text_entry="false"
     follows="top|right"
     layout="topleft"
     height="25"
     top_delta="-2"
     left_pad="3"
     max_chars="20"
     mouse_opaque="true"
     name="type"
     width="128">
        <combo_item name="AllTypes" value="All Types" label="All Types"/>
        <combo_item name="Auction" value="Auction" label="Auction"/>
        <combo_item name="MainlandSales" value="Mainland Sales" label="For Sale - Mainland"/>
        <combo_item name="EstateSales" value="Estate Sales" label="For Sale - Estate"/>
        <combo_box.combo_button
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
		<combo_box.drop_down_button
		pad_right="0"
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_pressed="ToolbarDropDown_Press" 
		image_pressed_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
    </combo_box>
    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowPGLand"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_PG_Dark"
     mouse_opaque="true"
     name="incpg"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowMatureLand"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_M_Dark"
     mouse_opaque="true"
     name="incmature"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowAdultLand"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_R_Dark"
     mouse_opaque="true"
     name="incadult"
     width="25" />
     <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="135"
    layout="topleft"
    left_pad="-2"
    top_delta="0"/>
    <check_box
     top_delta="3"
     layout="topleft"
     control_name="FindLandPrice"
     follows="left|top"
     font="SansSerifSmall"
     height="16"
     initial_value="true"
     label="Price &#8804; "
     left_delta="2"
     mouse_opaque="true"
     name="pricecheck"
     width="60" />
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     follows="left|top"
     layout="topleft"
     font="SansSerifSmall"
     top_delta="1"
     height="16"
     left_pad="1"
     max_length="10"
     mouse_opaque="true"
     name="priceedit"
     width="50" />
    <text
     bg_visible="false"
     border_visible="false"
     top_delta="2"
     follows="left|top"
     layout="topleft"
     font="SansSerifSmall"
     halign="left"
     height="16"
     left_pad="3"
     mouse_opaque="true"
     name="pricecheck_symbol"
     width="15">
        L$
    </text>
    <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="138"
    layout="topleft"
    left_pad="2"
    top_delta="-6"/>
    <check_box
     control_name="FindLandArea"
     follows="left|top"
     layout="topleft"
     font="SansSerifSmall"
     height="16"
     top_delta="3"
     initial_value="true"
     label="Area &#8805; "
     left_delta="2"
     mouse_opaque="true"
     name="areacheck"
     width="60" />
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     top_delta="1"
     follows="left|top"
     layout="topleft"
     font="SansSerifSmall"
     height="16"
     left_pad="1"
     max_length="10"
     mouse_opaque="true"
     name="areaedit"
     width="50" />
    <text
     bg_visible="false"
     border_visible="false"
     follows="left|top"
     layout="topleft"
     top_delta="3"
     left_pad="3"
     font="SansSerifSmall"
     halign="left"
     height="16"
     mouse_opaque="true"
     name="areacheck_symbol"
     width="15">
        m²
    </text>

    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="-7"
     left_pad="8"
     height="25"
     label="Search"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     mouse_opaque="true"
     name="Search"
     width="103" />
    <scroll_list
     background_visible="true"
     layout="topleft"
     top_pad="1"
     column_padding="0"
     draw_border="false"
     draw_heading="true"
     follows="left|top|right|bottom"
     height="480"
     left="2"
     mouse_opaque="true"
     multi_select="false"
     name="results"
     search_column="2"
     width="336">
     <column label="" name="icon" width="24" />
     <column dynamicwidth="true" label="Name" name="name" />
     <column label="Type" name="landtype" width="50" />
     <column label="L$ Price" name="price" width="65" />
     <column label="Area" name="area" width="50" />
     <column label="L$/m²" name="per_meter" width="65" />
    </scroll_list>
    <button
     image_overlay="Arrow_Left_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     hover_glow_amount="0.15"
     tool_tip="Previous page"
     follows="left|bottom"
     layout="topleft"
     height="23"
     left="2"
     top_pad="1"
     name="prev_btn"
     width="32" />
     <icon
    follows="left|bottom|right"
    image_name="Toolbar_Middle_Off"
    height="23"
    width="270"
    layout="topleft"
    left_pad="1"
    top_delta="0"/>
    <text
     bg_visible="false"
     border_visible="false"
     top_delta="5"
     follows="left|bottom"
     font="SansSerifSmall"
     h_pad="0"
     halign="center"
     height="16"
     left_delta="2"
     layout="topleft"
     mouse_opaque="true"
     name="result_text"
     v_pad="0"
     width="267" >
</text>
    <button
     image_overlay="Arrow_Right_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     tool_tip="Next page"
     follows="right|bottom"
     height="23"
     layout="topleft"
     left_pad="2"
     name="next_btn"
     top_delta="-5"
     width="32"/>
</panel>
