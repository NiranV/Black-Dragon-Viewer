<panel
 border="true"
 top="30"
 follows="left|top|right|bottom"
 height="533"
 label="Classifieds"
 left="1"
 left_delta="68"
 mouse_opaque="false"
 name="panel_dir_classified"
 width="758">
    <string name="searching_text">
        Searching...
    </string>
    <string name="not_found_text">
        None Found.
    </string>

     <icon
    follows="left|top|right"
    image_name="Toolbar_Middle_Off"
    height="25"
    width="443"
    layout="topleft"
    left="2"
    top_pad="2"/>
    <line_editor
     bevel_style="in"
     border_style="line"
     border_thickness="1"
     top_delta="2"
     follows="left|right|top"
     layout="topleft"
     font="SansSerif"
     height="20"
     left_delta="2"
     max_length="63"
     mouse_opaque="true"
     name="name"
     width="439" />
     <combo_box
     allow_text_entry="false"
     follows="right|top"
     layout="topleft"
     height="25"
     top_delta="-2"
     left_pad="3"
     max_chars="20"
     mouse_opaque="true"
     name="Category"
     width="128">
        <combo_item name="AnyCategory" value="0" label="Any Category"/>
        <combo_item name="Shopping" value="1" label="Shopping"/>
        <combo_item name="LandRental" value="2" label="Land Rental"/>
        <combo_item name="PropertyRental" value="3" label="Property Rental"/>
        <combo_item name="SpecialAttraction" value="4" label="Special Attraction"/>
        <combo_item name="NewProducts" value="5" label="New Products"/>
        <combo_item name="Employment" value="6" label="Employment"/>
        <combo_item name="Wanted" value="7" label="Wanted"/>
        <combo_item name="Service" value="8" label="Service"/>
        <combo_item name="Personal" value="9" label="Personal"/>
        <combo_box.combo_button
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
		<combo_box.drop_down_button
		pad_right="0"
		image_unselected="ToolbarDropDown_Off"
		image_selected="ToolbarDropDown_Press"
		image_pressed="ToolbarDropDown_Press" 
		image_pressed_selected="ToolbarDropDown_Press"
		image_disabled="ToolbarDropDown_Off" />
    </combo_box>
    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowPGClassifieds"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_PG_Dark"
     mouse_opaque="true"
     name="incpg"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowMatureClassifieds"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_M_Dark"
     mouse_opaque="true"
     name="incmature"
     width="25" />
     <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     control_name="ShowAdultClassifieds"
     initial_value="true"
     left_pad="1"
     height="25"
     label=""
     is_toggle="true"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     image_overlay="Parcel_R_Dark"
     mouse_opaque="true"
     name="incadult"
     width="25" />

    <button
     follows="right|top"
     layout="topleft"
     font="SansSerif"
     top_delta="0"
     left_pad="1"
     height="25"
     label="Search"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     mouse_opaque="true"
     name="Search"
     width="103" />
    <scroll_list
     background_visible="true"
     layout="topleft"
     top_pad="1"
     column_padding="0"
     draw_border="false"
     draw_heading="true"
     follows="left|top|right|bottom"
     height="480"
     left="2"
     mouse_opaque="true"
     multi_select="false"
     name="results"
     search_column="2"
     width="336">
     <column label="" name="icon" width="24" />
        <column label="" name="type" width="-1" />
        <column label="Name" name="name" width="225" />
        <column label="Price" name="price" width="55" />
    </scroll_list>
    <button
     image_overlay="Arrow_Left_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     hover_glow_amount="0.15"
     tool_tip="Previous page"
     follows="left|bottom"
     layout="topleft"
     height="23"
     left="2"
     top_pad="1"
     name="prev_btn"
     width="32" />
     <icon
    follows="left|bottom|right"
    image_name="Toolbar_Middle_Off"
    height="23"
    width="270"
    layout="topleft"
    left_pad="1"
    top_delta="0"/>
    <text
     bg_visible="false"
     border_visible="false"
     top_delta="5"
     follows="left|bottom"
     font="SansSerifSmall"
     h_pad="0"
     halign="center"
     height="16"
     left_delta="2"
     layout="topleft"
     mouse_opaque="true"
     name="result_text"
     v_pad="0"
     width="267" >
</text>
    <button
     image_overlay="Arrow_Right_Off"
     image_hover_unselected="Toolbar_Middle_Over"
     image_selected="Toolbar_Middle_Selected"
     image_unselected="Toolbar_Middle_Off"
     chrome="true"
     tool_tip="Next page"
     follows="right|bottom"
     height="23"
     layout="topleft"
     left_pad="2"
     name="next_btn"
     top_delta="-5"
     width="32"/>
</panel>
